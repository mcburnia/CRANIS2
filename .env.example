# CRANIS2 environment template — copy to `.env` and fill in.
#
# `.env` is gitignored and MUST NEVER be committed (CLAUDE.md rule 10).
#
# Legend:
#   [local]  safe to set to any local dev value / generate yourself
#   [gen]    generate a random secret, e.g. `openssl rand -hex 32`
#   [secret] real external credential — copy from the staging (minimac) .env;
#            the matching integration is disabled/broken without it
#
# For a minimal "boot the app for offline bugfixing" setup, the [local] and
# [gen] values are enough; leave [secret] blank or as placeholders and the
# core app still starts (external integrations just won't work).

# ── Datastores (cranis2 owns these locally — pick any dev values) ──────────
POSTGRES_USER=cranis2                       # [local]
POSTGRES_PASSWORD=                          # [gen]
POSTGRES_DB=cranis2                         # [local]
FORGEJO_DB_USER=forgejo                     # [local]
FORGEJO_DB_PASSWD=                          # [gen]
NEO4J_USER=neo4j                            # [local]
NEO4J_PASSWORD=                             # [gen] (min 8 chars; Neo4j rejects short)

# ── App config ────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3002          # [local] laptop dev URL
EMAIL_FROM=CRANIS2 <noreply@cranis2.dev>    # [local]
DEV_SKIP_EMAIL=true                         # [local] true = don't actually send email in dev
LOG_LEVEL=info                              # [local]

# ── App secrets (generate locally; on a fresh local DB these need not match
#    staging — they only have to be internally consistent) ──────────────────
JWT_SECRET=                                 # [gen]
GITHUB_ENCRYPTION_KEY=                      # [gen] 32-byte hex; encrypts stored PATs
GITHUB_WEBHOOK_SECRET=                      # [gen]
CODEBERG_WEBHOOK_SECRET=                    # [gen]
CRANIS2_SIGNING_KEY=                        # [gen] (or run scripts/generate-signing-keys.sh)
WELCOME_USER=admin                          # [local]
WELCOME_PASS=                               # [gen]
WELCOME_SECRET=                             # [gen]

# ── External integrations — copy from the minimac .env for these to work ───
RESEND_API_KEY=                             # [secret] transactional email
ANTHROPIC_API_KEY=                          # [secret] AI category/summary features
GITHUB_CLIENT_ID=                           # [secret] GitHub OAuth app
GITHUB_CLIENT_SECRET=                       # [secret]
CODEBERG_CLIENT_ID=                         # [secret] Codeberg OAuth app
CODEBERG_CLIENT_SECRET=                     # [secret]
STRIPE_SECRET_KEY=                          # [secret] billing
STRIPE_WEBHOOK_SECRET=                      # [secret]
STRIPE_PRODUCT_ID=                          # [secret]
STRIPE_PRICE_ID=                            # [secret]
STRIPE_PUBLISHABLE_KEY=                     # [secret]
SCW_ACCESS_KEY=                             # [secret] Scaleway object storage
SCW_SECRET_KEY=                             # [secret]
SCW_REGION=fr-par                           # [local]
SCW_BUCKET_NAME=                            # [secret]
FORGEJO_ADMIN_TOKEN=                        # [secret] escrow Forgejo admin API
FORGEJO_URL=http://forgejo:3000             # [local] internal Docker DNS
JIRA_API_TOKEN=                             # [secret] daily roadmap rebuild
JIRA_EMAIL=andi.mcburnie@gmail.com          # [local]
