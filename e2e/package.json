{
  "name": "cranis2-e2e",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "./run-tests.sh all",
    "test:smoke": "./run-tests.sh smoke",
    "test:acceptance": "./run-tests.sh acceptance",
    "test:break": "./run-tests.sh break",
    "test:file": "./run-tests.sh",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "test:ui": "npx playwright test --ui",
    "report": "npx playwright show-report",
    "push-results": "node push-results.mjs",
    "test:push": "npx playwright test && node push-results.mjs",
    "setup": "npx playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "pg": "^8.19.0"
  },
  "overrides": {
    "hono": "^4.12.14",
    "@hono/node-server": "^1.19.13",
    "lodash": "^4.18.0",
    "path-to-regexp": "^8.4.0",
    "picomatch": "^4.0.4",
    "brace-expansion": "^5.0.5",
    "postcss": "^8.5.10",
    "flatted": "^3.4.2"
  },
  "license": "LicenseRef-Cranis2-Proprietary",
  "author": "Andrew (Andi) MCBURNIE <andi@mcburnie.com>"
}
